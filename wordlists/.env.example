# Bitcoin Node Connection Configuration
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=your_user
BITCOIN_RPC_PASSWORD=your_password
BITCOIN_RPC_TIMEOUT=30
BITCOIN_NETWORK=mainnet  # mainnet, testnet, regtest

# Security Configuration
BITCOIN_RPC_USE_SSL=false
BITCOIN_RPC_SSL_VERIFY=true
BITCOIN_RPC_SSL_CERT_PATH=

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FILE=bitcoin_rpc.log

# Brute Force Configuration
MAX_COMBINATIONS_WARNING=1000000
BATCH_SIZE=100
ADDRESSES_TO_SCAN=20
SCAN_DELAY_MS=100

# BIP-39 Configuration
WORDLIST_FILE=bip39_italian.txt
DEFAULT_PASSPHRASE=